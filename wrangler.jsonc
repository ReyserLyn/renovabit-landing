{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "renovabit-landing",
	"compatibility_date": "2026-07-09",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": "./dist"
	},
	"routes": [
		{
			"pattern": "renovabit.com",
			"custom_domain": true
		}
	],
	"vars": {
		"PUBLIC_INDEXABLE": "true"
	},
	"observability": {
		"enabled": true
	}
}
