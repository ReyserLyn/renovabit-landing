---
import "@/styles/landing.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "RenovaBit — Servicio técnico de laptops y PCs en Arequipa" } =
	Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{title}</title>
		<meta name="description" content={description}>
	</head>

	<body>
		<slot />
	</body>
</html>
