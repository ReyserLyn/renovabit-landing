---
import { Icon } from "astro-icon/components";

const steps = [
	{
		num: "01",
		icon: "hugeicons:message-01",
		title: "Elige la modalidad que mejor se adapte a ti.",
		description:
			"Escríbenos por WhatsApp y cuéntanos qué necesitas. Analizaremos tu caso, resolveremos tus dudas y te propondremos la solución más adecuada para tu proyecto o equipo desde el primer contacto.",
	},
	{
		num: "02",
		icon: "hugeicons:search-01",
		title: "Evaluamos la mejor solución.",
		description:
			"Analizamos tu caso y te explicamos las opciones disponibles antes de realizar cualquier trabajo. Si se trata de una reparación, el diagnóstico no tiene costo cuando decides realizar el servicio con nosotros.",
	},
	{
		num: "03",
		icon: "hugeicons:wrench-01",
		title: "Realizamos el trabajo.",
		description:
			"Utilizamos materiales de calidad, buenas prácticas y mantenemos una comunicación constante durante todo el proceso para que sepas cómo avanza tu servicio.",
	},
	{
		num: "04",
		icon: "hugeicons:task-01",
		title: "Documentamos cada etapa.",
		description:
			"Cuando el servicio lo requiere, registramos el proceso mediante fotografías e informes técnicos para que tengas total claridad sobre el trabajo realizado.",
	},
	{
		num: "05",
		icon: "hugeicons:checkmark-badge-01",
		title: "Entregamos y damos seguimiento.",
		description:
			"Una vez finalizado el servicio verificamos que todo funcione correctamente y resolvemos cualquier duda para que puedas aprovechar al máximo tu equipo o proyecto.",
	},
];
---

<section class="py-20 md:py-28">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mx-auto max-w-2xl text-center">
			<h2
				class="font-heading text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl"
			>
				Nos encargamos de todo el proceso.
			</h2>
			<p class="mt-4 text-base text-muted-foreground sm:text-lg">
				Desde el primer mensaje hasta la entrega final, buscamos que el proceso sea claro,
				transparente y sin complicaciones.
			</p>
		</div>

		<div class="relative mx-auto mt-20 max-w-lg md:mt-24">
			<!-- Línea vertical -->
			<div
				class="absolute left-6 top-0 bottom-0 w-px bg-primary/15 md:left-1/2 md:-translate-x-1/2"
				aria-hidden="true"
			></div>

			<div class="flex flex-col gap-12">
				{steps.map((step, i) => {
					const isLeft = i % 2 === 0;

					return (
						<div class="relative md:grid md:grid-cols-2 md:items-start md:gap-8 animate-fade-in-up view-animate-[--entrance] animate-duration-slower">
							{/* Ícono */}
							<div
								class:list={[
									"relative z-10 flex size-12 shrink-0 items-center justify-center rounded-xl border-2 bg-background md:absolute md:left-1/2 md:-translate-x-1/2",
									isLeft ? "border-primary/20" : "border-primary/30",
								]}
								aria-hidden="true"
							>
								<Icon
									name={step.icon}
									class:list={["size-5", isLeft ? "text-primary" : "text-primary"]}
								/>
							</div>

							{/* Contenido */}
							<div
								class:list={[
									"ml-16 md:ml-0",
									isLeft ? "md:pr-10 md:text-right" : "md:col-start-2 md:pl-10",
								]}
							>
								<span class="font-heading text-xs font-bold tracking-widest text-primary uppercase">
									Paso {step.num}
								</span>
								<h3 class="mt-2 font-heading text-lg font-bold tracking-tight text-foreground sm:text-xl">
									{step.title}
								</h3>
								<p class="mt-2 text-sm leading-relaxed text-muted-foreground sm:text-base">
									{step.description}
								</p>
							</div>
						</div>
					);
				})}
			</div>
		</div>

		<div class="mt-20 flex flex-col items-center gap-5 text-center">
			<p class="max-w-lg text-base text-muted-foreground sm:text-lg">
				Un buen servicio no solo se mide por el resultado, sino también por la experiencia durante
				todo el proceso.
			</p>
		</div>
	</div>
</section>
