---
import aboutImg1 from "@/assets/images/about/conocenos-1.webp";
import servicioImg3 from "@/assets/images/services/soporte-remoto.avif";
import testimonialImg from "@/assets/images/testimonials/testimonial.avif";
import { Badge } from "@/components/ui/badge";
import { Rating } from "@/components/ui/rating";
---

<section id="resenas" class="py-20 md:py-28 scroll-mt-24">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Título + subtítulo -->
		<div class="mx-auto max-w-2xl text-center">
			<h2
				class="font-heading text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl"
			>
				La confianza se construye con resultados.
			</h2>
			<p class="mt-4 text-base text-muted-foreground sm:text-lg">
				Personas, profesionales y empresas que confiaron en RenovaBit para resolver sus necesidades
				tecnológicas.
			</p>
		</div>

		<!-- Testimonio destacado -->
		<div class="mt-20 mx-auto max-w-4xl">
			<h3
				class="text-center font-heading text-xl font-bold tracking-tight text-foreground sm:text-2xl"
			>
				Testimonio destacado
			</h3>

			<div
				class="mt-8 grid gap-4 sm:grid-cols-2 sm:gap-6 animate-fade-in-up view-animate-[--entrance] animate-duration-slower"
			>
				<!-- Antes -->
				<div class="flex flex-col items-center">
					<span class="text-xs font-bold tracking-wider text-muted-foreground uppercase">
						Antes
					</span>
					<div class="mt-3 max-w-sm overflow-hidden rounded-2xl sm:max-w-none">
						<img
							src={aboutImg1.src}
							alt="Estado inicial del equipo antes del servicio técnico"
							width={aboutImg1.width}
							height={aboutImg1.height}
							loading="lazy"
							decoding="async"
							class="aspect-4/3 w-full object-cover"
						>
					</div>
				</div>

				<!-- Después -->
				<div class="flex flex-col items-center">
					<span class="text-xs font-bold tracking-wider text-muted-foreground uppercase">
						Después
					</span>
					<div class="mt-3 max-w-sm overflow-hidden rounded-2xl sm:max-w-none">
						<img
							src={testimonialImg.src}
							alt="Resultado final del equipo tras la reparación"
							width={testimonialImg.width}
							height={testimonialImg.height}
							loading="lazy"
							decoding="async"
							class="aspect-4/3 w-full object-cover"
						>
					</div>
				</div>
			</div>

			<!-- Info del testimonio -->
			<div class="mt-8 flex flex-col items-center text-center">
				<div class="flex w-full justify-around gap-2">
					<Badge variant="secondary">Limpieza</Badge>
					<Badge variant="secondary">Mantenimiento</Badge>
					<Badge variant="secondary">Instalación</Badge>
				</div>

				<div class="mt-5 flex items-center gap-2.5">
					<Rating stars={5} />
				</div>

				<p class="mt-4 font-heading text-base font-bold text-foreground">Sr. Manuel</p>

				<blockquote class="mt-2 text-base leading-relaxed text-muted-foreground">
					"Solicité el servicio a domicilio y quedé sorprendido con la puntualidad y
					profesionalismo. Me hicieron mantenimiento, revisión de la tarjeta gráfica e instalación
					de programas. Tener todo resuelto en mi hogar fue una gran ayuda."
				</blockquote>
			</div>
		</div>

		<!-- Segunda reseña: imagen + texto -->
		<div
			class="mt-20 mx-auto max-w-4xl grid grid-cols-1 gap-8 md:grid-cols-[5fr_7fr] md:items-center md:gap-8 animate-fade-in-up view-animate-[--entrance] animate-duration-slower"
		>
			<!-- Imagen + badges -->
			<div>
				<div class="overflow-hidden rounded-2xl max-w-sm mx-auto md:max-w-none">
					<img
						src={servicioImg3.src}
						alt="Laptop reparada y funcionando tras el servicio técnico"
						width={servicioImg3.width}
						height={servicioImg3.height}
						loading="lazy"
						decoding="async"
						class="aspect-4/3 w-full object-cover"
					>
				</div>
				<div class="mt-3 flex justify-around gap-2">
					<Badge variant="secondary">Reparación</Badge>
					<Badge variant="secondary">A domicilio</Badge>
				</div>
			</div>

			<!-- Review -->
			<div class="text-center md:text-left">
				<div class="flex items-center justify-center gap-2.5 md:justify-start">
					<Rating stars={5} />
				</div>

				<p class="mt-4 font-heading text-base font-bold text-foreground">Sra. Carmen</p>

				<blockquote class="mt-2 text-base leading-relaxed text-muted-foreground">
					"Llevé mi laptop porque no encendía y tenía la pantalla dañada. Me explicaron todo el
					proceso con paciencia, el diagnóstico fue gratuito y en dos días ya tenía mi equipo como
					nuevo. El seguimiento posterior fue impecable. Los recomiendo totalmente."
				</blockquote>
			</div>
		</div>
	</div>
</section>
