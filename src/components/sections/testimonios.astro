---
import { Image } from "astro:assets";
import { Badge } from "@/components/ui/badge";
import { Rating } from "@/components/ui/rating";
import { testimonios } from "@/data/testimonios";

const destacado = testimonios.find((t) => t.visual?.destacado);
const secundarios = testimonios.filter((t) => !t.visual?.destacado);
---

<section id="resenas" class="py-20 md:py-28 scroll-mt-24">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Título + subtítulo -->
		<div class="mx-auto max-w-2xl text-center">
			<h2
				class="font-heading text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl"
			>
				La confianza se construye con resultados.
			</h2>
			<p class="mt-4 text-base text-muted-foreground sm:text-lg">
				Personas, profesionales y empresas que confiaron en RenovaBit para resolver sus necesidades
				tecnológicas.
			</p>
		</div>

		{destacado && (
				<div class="mt-20 mx-auto max-w-4xl">
					<h3
						class="text-center font-heading text-xl font-bold tracking-tight text-foreground sm:text-2xl"
					>
						Testimonio destacado
					</h3>

					{destacado.visual?.imagenes?.antes && destacado.visual?.imagenes?.despues && (
						<div
							class="mt-8 grid gap-4 sm:grid-cols-2 sm:gap-6 animate-fade-in-up view-animate-[--entrance] animate-duration-slower"
						>
							<div class="flex flex-col items-center">
								<span class="text-xs font-bold tracking-wider text-muted-foreground uppercase">
									Antes
								</span>
								<div class="mt-3 max-w-sm overflow-hidden rounded-2xl sm:max-w-none">
									<Image
										src={destacado.visual.imagenes.antes}
										alt={`Antes del servicio: ${destacado.visual.badges.join(", ")}`}
										widths={[400, 800]}
										sizes="(max-width: 640px) 100vw, 50vw"
										loading="lazy"
										decoding="async"
										class="aspect-4/3 w-full object-cover"
									/>
								</div>
							</div>

							<div class="flex flex-col items-center">
								<span class="text-xs font-bold tracking-wider text-muted-foreground uppercase">
									Después
								</span>
								<div class="mt-3 max-w-sm overflow-hidden rounded-2xl sm:max-w-none">
									<Image
										src={destacado.visual.imagenes.despues}
										alt={`Después del servicio: ${destacado.visual.badges.join(", ")}`}
										widths={[400, 800]}
										sizes="(max-width: 640px) 100vw, 50vw"
										loading="lazy"
										decoding="async"
										class="aspect-4/3 w-full object-cover"
									/>
								</div>
							</div>
						</div>
					)}

					<div class="mt-8 flex flex-col items-center text-center">
						<div class="flex w-full justify-around gap-2">
							{destacado.visual?.badges.map((badge) => (
								<Badge variant="secondary">{badge}</Badge>
							))}
						</div>

						<div class="mt-5 flex items-center gap-2.5">
							<Rating stars={destacado.rating} />
						</div>

						<p class="mt-4 font-heading text-base font-bold text-foreground">
							{destacado.rol ? `${destacado.autor} — ${destacado.rol}` : destacado.autor}
						</p>

						<blockquote class="mt-2 text-base leading-relaxed text-muted-foreground">
							"{destacado.texto}"
						</blockquote>
					</div>
				</div>
			)}

		{secundarios.map((t) => (
				<div
					class="mt-20 mx-auto max-w-4xl grid grid-cols-1 gap-8 md:grid-cols-[5fr_7fr] md:items-center md:gap-8 animate-fade-in-up view-animate-[--entrance] animate-duration-slower"
				>
					<div>
						{t.visual?.imagenes?.principal && (
							<>
								<div class="overflow-hidden rounded-2xl max-w-sm mx-auto md:max-w-none">
									<Image
											src={t.visual.imagenes.principal}
										alt={`${t.autor}: ${t.visual.badges.join(", ")}`}
										widths={[400, 800]}
										sizes="(max-width: 640px) 100vw, 50vw"
										loading="lazy"
										decoding="async"
										class="aspect-4/3 w-full object-cover"
									/>
								</div>
								<div class="mt-3 flex justify-around gap-2">
									{t.visual.badges.map((badge) => (
										<Badge variant="secondary">{badge}</Badge>
									))}
								</div>
							</>
						)}
					</div>

					<div class="text-center md:text-left">
						<div class="flex items-center justify-center gap-2.5 md:justify-start">
							<Rating stars={t.rating} />
						</div>

						<p class="mt-4 font-heading text-base font-bold text-foreground">
							{t.rol ? `${t.autor} — ${t.rol}` : t.autor}
						</p>

						<blockquote class="mt-2 text-base leading-relaxed text-muted-foreground">
							"{t.texto}"
						</blockquote>
					</div>
				</div>
			))}
	</div>
</section>
