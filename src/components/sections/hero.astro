---
import { Image } from "astro:assets";
import GridDotsBackground from "@astroanimate/core/GridDotsBackground";
import HighlightText from "@astroanimate/core/HighlightText";
import { Icon } from "astro-icon/components";
import heroImg1 from "@/assets/images/hero/hero-1.avif";
import heroImg2 from "@/assets/images/hero/hero-2.avif";
import heroImg3 from "@/assets/images/hero/hero-3.avif";
import heroImg4 from "@/assets/images/hero/hero-4.avif";
import WhatsappIcon from "@/components/social-icon/WhatsappIcon.astro";
import { Button } from "@/components/ui/button";
import { CONTACT } from "@/constants";
---

<GridDotsBackground
	variant="dots"
	animate={true}
	mask={true}
	height="100%"
	bgColor="transparent"
	dotColor="oklch(0.57 0.2248 281.4451 / 0.08)"
	gap="28px"
>
	<section
		class="relative z-10 flex flex-col pt-24 pb-8 md:min-h-dvh md:justify-center md:pt-24 md:pb-10"
	>
		<div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
			<!-- Row 1: 50/50 -->
			<div class="grid gap-10 lg:grid-cols-2 lg:gap-16">
				<!-- Left: Texto -->
				<div class="flex flex-col justify-center">
					<h1
						class="font-heading text-4xl font-bold leading-tight tracking-tight text-foreground sm:text-5xl lg:text-6xl animate-fade-in-up animate-duration-slower"
					>
						Servicio técnico de laptops y PCs

						<HighlightText
							color="oklch(0.57 0.2248 281.4451 / 0.18)"
							trigger="load"
							duration="800ms"
							delay="300ms"
							thickness="100%"
						>
							en Arequipa
						</HighlightText>
					</h1>
					<p
						class="mt-5 max-w-lg text-base leading-relaxed text-muted-foreground sm:text-lg animate-fade-in-up animate-delay-200 animate-duration-slower"
					>
						Reparamos laptops y PCs en Arequipa con diagnóstico claro, precio justo y atención sin
						tecnicismos. Servicio a domicilio para personas y empresas.
					</p>
					<div
						class="mt-7 flex flex-wrap gap-3 sm:gap-4 animate-fade-in-up animate-delay-400 animate-duration-normal"
					>
						<Button as="a" href="/#servicios" variant="default" size="lg" class="gap-2">
							<Icon name="hugeicons:arrow-right-01" class="size-5" />Cotiza tu servicio
						</Button>
						<Button
							as="a"
							href={CONTACT.whatsappUrl}
							target="_blank"
							rel="noopener noreferrer"
							variant="secondary"
							size="lg"
							class="gap-2"
						>
							<WhatsappIcon size={18} />Escríbenos por WhatsApp
						</Button>
					</div>
				</div>

				<!-- Right: Grid de imágenes -->
				<div
					class="grid grid-cols-2 gap-3 sm:gap-4 animate-blurred-fade-in animate-delay-300 animate-duration-slower"
				>
					<!-- wide top -->
					<div class="col-span-2 overflow-hidden rounded-2xl border border-border/50 aspect-7/2">
						<Image
							src={heroImg1}
							alt="Herramientas del taller de RenovaBit: fuente de poder, microscopio y equipo de reparación profesional en Arequipa"
							widths={[400, 800]}
							sizes="(max-width: 768px) 100vw, 50vw"
							fetchpriority="high"
							loading="eager"
							decoding="sync"
							class="size-full object-cover"
						/>
					</div>
					<!-- square left -->
					<div class="overflow-hidden rounded-2xl border border-border/50 aspect-7/4">
						<Image
							src={heroImg2}
							alt="Placa de laptop con acumulación de polvo antes del mantenimiento RenovaBit"
							widths={[200, 400]}
							sizes="(max-width: 768px) 100vw, 25vw"
							loading="lazy"
							decoding="async"
							class="size-full object-cover"
						/>
					</div>
					<!-- square right -->
					<div class="overflow-hidden rounded-2xl border border-border/50 aspect-7/4">
						<Image
							src={heroImg3}
							alt="Placa de laptop limpia tras mantenimiento profesional RenovaBit"
							widths={[200, 400]}
							sizes="(max-width: 768px) 100vw, 25vw"
							loading="lazy"
							decoding="async"
							class="size-full object-cover"
						/>
					</div>
					<!-- wide bottom -->
					<div class="col-span-2 overflow-hidden rounded-2xl border border-border/50 aspect-7/2">
						<Image
							src={heroImg4}
							alt="Soporte técnico remoto RenovaBit: instalación de programas, formateo y sistema operativo"
							widths={[400, 800]}
							sizes="(max-width: 768px) 100vw, 50vw"
							loading="lazy"
							decoding="async"
							class="size-full object-cover"
						/>
					</div>
				</div>
			</div>

			<!-- Row 2: Checks zigzag -->
			<ul
				class="mt-10 grid list-none grid-cols-2 justify-items-center gap-x-6 gap-y-3 text-base text-muted-foreground sm:grid-cols-4 sm:gap-x-4 sm:gap-y-3 md:mt-28"
			>
				<li
					class="col-start-1 row-start-1 sm:col-start-1 sm:row-start-1 inline-flex items-center gap-2 animate-fade-in-up animate-delay-500 animate-duration-slow"
				>
					<Icon
						name="hugeicons:checkmark-circle-03"
						class="size-4 shrink-0 text-primary/80"
					/>Boleta y Factura
				</li>
				<li
					class="col-start-2 row-start-2 sm:col-start-2 sm:row-start-2 inline-flex items-center gap-2 animate-fade-in-up animate-delay-600 animate-duration-slow"
				>
					<Icon
						name="hugeicons:checkmark-circle-03"
						class="size-4 shrink-0 text-primary/80"
					/>Atención en Arequipa
				</li>
				<li
					class="col-start-1 row-start-3 sm:col-start-3 sm:row-start-1 inline-flex items-center gap-2 animate-fade-in-up animate-delay-700 animate-duration-slow"
				>
					<Icon
						name="hugeicons:checkmark-circle-03"
						class="size-4 shrink-0 text-primary/80"
					/>Servicio a Domicilio
				</li>
				<li
					class="col-start-2 row-start-4 sm:col-start-4 sm:row-start-2 inline-flex items-center gap-2 animate-fade-in-up animate-delay-800 animate-duration-slow"
				>
					<Icon
						name="hugeicons:checkmark-circle-03"
						class="size-4 shrink-0 text-primary/80"
					/>Personas y Empresas
				</li>
			</ul>
		</div>
	</section>
</GridDotsBackground>
