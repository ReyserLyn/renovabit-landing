---
import { Icon } from "astro-icon/components";
import aboutImg from "@/assets/images/about/conocenos-1.webp";
import servicioImg2 from "@/assets/images/services/mantenimiento.avif";
import servicioImg3 from "@/assets/images/services/soporte-remoto.avif";
import servicioImg1 from "@/assets/images/services/taller.avif";
import { Button } from "@/components/ui/button";

const servicios = [
	{
		num: "01",
		nombre: "Servicio Técnico",
		img: servicioImg1,
		items: ["Mantenimiento", "Limpieza", "Diagnóstico", "PC y Laptop"],
		col: "1",
		row: "1",
	},
	{
		num: "02",
		nombre: "Desarrollo Web",
		img: servicioImg3,
		items: ["Landing Pages", "Web Corporativas", "Catálogos", "Automatizaciones"],
		col: "2",
		row: "2",
	},
	{
		num: "03",
		nombre: "Tienda",
		img: servicioImg2,
		items: ["Equipos", "Componentes CPU", "Periféricos"],
		col: "2",
		row: "6",
	},
	{
		num: "04",
		nombre: "Reparaciones Especializadas",
		img: aboutImg,
		items: ["Bios", "Microeletrónica", "Pantallas", "Teclados"],
		col: "1",
		row: "8",
	},
];
---

<section class="py-16 md:py-24">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Título + subtítulo -->
		<div class="mx-auto max-w-2xl text-center">
			<h2
				class="font-heading text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl"
			>
				Nuestros Servicios
			</h2>
			<p class="mt-4 text-base text-muted-foreground sm:text-lg">
				Soluciones tecnológicas diseñadas para personas, profesionales y empresas.
			</p>
		</div>

		<div
			class="mt-12 grid grid-cols-1 gap-y-12 sm:grid-cols-2 sm:gap-x-10 sm:gap-y-0 lg:mx-auto lg:max-w-3xl"
		>
			{servicios.map((s) => (
				<div
					class:list={[
						"group flex flex-col animate-fade-in-up animate-duration-slower sm:row-span-3",
						`sm:col-start-${s.col} sm:row-start-${s.row}`,
					]}
				>
						{/* Imagen */}
						<div class="overflow-hidden rounded-2xl">
							<img
								src={s.img.src}
								alt={s.nombre}
								width={s.img.width}
								height={s.img.height}
								loading="lazy"
								decoding="async"
								class="aspect-4/3 w-full object-cover transition-transform duration-500 group-hover:scale-105"
							/>
						</div>

						{/* Número + Nombre */}
						<div class="relative mt-10 mx-auto w-full max-w-72 sm:mt-6">
							<span
								class="absolute -top-7 left-0 font-heading text-8xl font-black leading-none tracking-tighter text-primary/10 select-none sm:-top-6"
							>
								{s.num}
							</span>
							<h3
								class="pl-14 font-heading text-3xl font-bold leading-tight text-foreground sm:text-4xl"
							>
								{s.nombre}
							</h3>
						</div>

						{/* Lista */}
						<ul class="mt-10 space-y-2.5 pl-8 sm:mt-6 sm:pl-0">
							{
								s.items.map((item) => (
									<li class="flex items-center gap-3 text-lg text-muted-foreground">
										<span class="block h-px w-5 shrink-0 bg-primary/50" />
										{item}
									</li>
								))
							}
						</ul>
					</div>
			))}
			<div class="hidden sm:block sm:col-span-2 sm:row-start-5 sm:h-8" aria-hidden="true" />
		</div>

		<div
			class="mt-14 flex flex-col items-center gap-5 pt-14 text-center animate-fade-in-up animate-duration-slower"
		>
			<p class="font-heading text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
				¿Necesitas alguno de nuestros servicios?
			</p>
			<Button as="a" href="/#contacto" variant="default" size="lg" class="gap-2">
				<Icon name="hugeicons:arrow-right-01" class="size-5" />
				Contáctanos
			</Button>
		</div>
	</div>
</section>
