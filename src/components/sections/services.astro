---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import servicioImg1 from "@/assets/images/services/service-1.avif";
import servicioImg2 from "@/assets/images/services/service-2.avif";
import servicioImg3 from "@/assets/images/services/service-3.avif";
import servicioImg4 from "@/assets/images/services/service-4.avif";
import { Button } from "@/components/ui/button";
import { CONTACT } from "@/constants";

const servicios = [
	{
		num: "01",
		nombre: "Servicio Técnico",
		img: servicioImg1,
		alt: "Taller completo de RenovaBit con herramientas y equipos de reparación profesional en Arequipa",
		items: ["Mantenimiento", "Limpieza", "Diagnóstico", "PC y Laptop"],
		col: "1",
		row: "1",
		colClass: "sm:col-start-1",
		rowClass: "sm:row-start-1",
	},
	{
		num: "02",
		nombre: "Desarrollo Web",
		img: servicioImg2,
		alt: "Desarrollo web corporativo: sitio de Bodega Manchego, proyecto reciente de RenovaBit",
		items: ["Landing Pages", "Web Corporativas", "Catálogos", "Automatizaciones"],
		col: "2",
		row: "2",
		colClass: "sm:col-start-2",
		rowClass: "sm:row-start-2",
	},
	{
		num: "03",
		nombre: "Tienda",
		img: servicioImg3,
		alt: "Tienda online de RenovaBit: venta de equipos, componentes y periféricos",
		items: ["Equipos", "Componentes CPU", "Periféricos"],
		col: "2",
		row: "6",
		colClass: "sm:col-start-2",
		rowClass: "sm:row-start-6",
	},
	{
		num: "04",
		nombre: "Reparaciones Especializadas",
		img: servicioImg4,
		alt: "Placa de laptop Lenovo ThinkPad tras mantenimiento profesional RenovaBit",
		items: ["Bios", "Microelectrónica", "Pantallas", "Teclados"],
		col: "1",
		row: "8",
		colClass: "sm:col-start-1",
		rowClass: "sm:row-start-8",
	},
];
---

<section id="servicios" class="py-16 md:py-24 scroll-mt-24">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Título + subtítulo -->
		<div class="mx-auto max-w-2xl text-center">
			<h2
				class="font-heading text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl"
			>
				Nuestros Servicios
			</h2>
			<p class="mt-4 text-base text-muted-foreground sm:text-lg">
				Reparación de laptops, mantenimiento de PCs, desarrollo web y venta de componentes en
				Arequipa.
			</p>
		</div>

		<div
			class="mt-12 grid grid-cols-1 gap-y-12 sm:grid-cols-2 sm:gap-x-10 sm:gap-y-0 lg:mx-auto lg:max-w-3xl"
		>
			{servicios.map((s) => (
				<article
					class:list={[
						"group flex flex-col animate-fade-in-up animate-duration-slower sm:row-span-3",
						s.colClass,
						s.rowClass,
					]}
				>
						{/* Imagen */}
						<div class="overflow-hidden rounded-2xl w-3/4 mx-auto sm:w-full">
							<Image
								src={s.img}
								alt={s.alt}
								widths={[400, 800]}
								sizes="(max-width: 640px) 75vw, (max-width: 1024px) 50vw, 33vw"
								loading="lazy"
								decoding="async"
								class="aspect-4/3 w-full object-cover transition-transform duration-500 group-hover:scale-105"
							/>
						</div>

						{/* Número + Nombre */}
						<div class="relative mt-10 mx-auto w-full max-w-72 sm:mt-6">
							<span
								class="absolute -z-10 -top-7 left-0 font-heading text-8xl font-black leading-none tracking-tighter text-primary/60 select-none sm:-top-6"
								aria-hidden="true"
							>
								{s.num}
							</span>
							<h3
								class="pl-14 font-heading text-3xl font-bold leading-tight text-foreground sm:text-4xl"
							>
								{s.nombre}
							</h3>
						</div>

						{/* Lista */}
						<ul class="mt-10 space-y-2.5 pl-8 sm:mt-6 sm:pl-0">
							{
								s.items.map((item) => (
									<li class="flex items-center gap-3 text-lg text-muted-foreground">
										<span class="block h-px w-5 shrink-0 bg-primary/50" aria-hidden="true" />
										{item}
									</li>
								))
							}
						</ul>
					</article>
			))}
			<div class="hidden sm:block sm:col-span-2 sm:row-start-5 sm:h-8" aria-hidden="true" />
		</div>

		<div
			class="mt-14 flex flex-col items-center gap-5 pt-14 text-center animate-fade-in-up animate-duration-slower"
		>
			<p class="font-heading text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
				¿Cuál servicio necesitas?
			</p>
			<Button
				as="a"
				href={CONTACT.whatsappUrl}
				target="_blank"
				rel="noopener noreferrer"
				variant="default"
				size="lg"
				class="gap-2"
			>
				<Icon name="hugeicons:arrow-right-01" class="size-5" />
				Cotizar servicio
			</Button>
		</div>
	</div>
</section>
