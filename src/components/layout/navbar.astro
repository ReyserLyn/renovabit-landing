---
import { Icon } from "astro-icon/components";
import logoSvg from "@/assets/branding/logo-horizontal-light.svg";
import WhatsappIcon from "@/components/social-icon/WhatsappIcon.astro";
import { Button } from "@/components/ui/button";
import { CONTACT, NAV_ITEMS, SITE } from "@/constants";
---

<!-- Skip link -->
<a
	href="#contenido-principal"
	class="sr-only focus:not-sr-only focus:fixed focus:inset-x-4 focus:top-4 focus:z-60 focus:mx-auto focus:w-fit focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-primary-foreground"
>
	Saltar al contenido
</a>

<header
	class="fixed top-0 left-1/2 z-50 mt-4 flex w-[calc(100%-2rem)] max-w-7xl -translate-x-1/2 flex-col rounded-2xl border bg-background transition-all duration-300"
>
	<div class="flex items-center justify-between px-6 py-2 md:px-8">
		<!-- Logo -->
		<a href="/" class="flex shrink-0 items-center select-none" draggable="false">
			<img
				src={logoSvg.src}
				alt={SITE.name}
				fetchpriority="high"
				width={logoSvg.width}
				draggable="false"
				height={logoSvg.height}
				class="h-9 w-auto md:h-10"
			>
		</a>

		<!-- Desktop nav -->
		<nav class="hidden items-center gap-10 md:flex" aria-label="Principal">
			{NAV_ITEMS.map((item) => (
				<a
					href={item.href}
					class="text-sm font-medium text-muted-foreground transition-colors duration-200 hover:text-primary"
				>
					{item.label}
				</a>
			))}
			<Button
				as="a"
				href={CONTACT.whatsappUrl}
				target="_blank"
				rel="noopener noreferrer"
				variant="whatsapp"
				size="sm"
				class="flex items-center gap-1"
			>
				<WhatsappIcon size={16} class="text-white" />
				Solicitar cotización
			</Button>
		</nav>

		<!-- Mobile: hamburger + WhatsApp -->
		<div class="flex items-center gap-3 md:hidden">
			<Button
				as="a"
				href={CONTACT.whatsappUrl}
				target="_blank"
				rel="noopener noreferrer"
				variant="whatsapp"
				size="sm"
				class="flex items-center gap-1"
			>
				<WhatsappIcon size={16} class="text-white" />
				WhatsApp
			</Button>
			<button
				type="button"
				id="mobile-menu-toggle"
				class="inline-flex size-9 items-center justify-center rounded-full text-muted-foreground transition-colors hover:text-foreground"
				aria-label="Abrir menú"
				aria-expanded="false"
			>
				<span id="menu-icon-open" class="block"
					><Icon name="hugeicons:menu-01" class="size-5" /></span
				>
				<span id="menu-icon-close" class="hidden"
					><Icon name="hugeicons:cancel-01" class="size-5" /></span
				>
			</button>
		</div>
	</div>

	<!-- Mobile dropdown -->
	<nav
		id="mobile-menu"
		class="hidden border-t border-border/20 px-6 pb-6 pt-4 md:hidden"
		aria-label="Menú móvil"
	>
		<div class="flex flex-col gap-1">
			{NAV_ITEMS.map((item) => (
				<a
					href={item.href}
					class="rounded-lg px-3 py-2.5 text-base font-medium text-foreground transition-colors hover:bg-muted/50"
				>
					{item.label}
				</a>
			))}
		</div>
		<div class="mt-4">
			<Button
				as="a"
				href={CONTACT.whatsappUrl}
				target="_blank"
				rel="noopener noreferrer"
				variant="whatsapp"
				size="default"
				class="w-full gap-2"
			>
				<WhatsappIcon size={18} class="text-white" />
				Solicitar cotización
			</Button>
		</div>
	</nav>
</header>

<script>
const header = document.querySelector("header");
const toggle = document.getElementById("mobile-menu-toggle");
const menu = document.getElementById("mobile-menu");
const iconOpen = document.getElementById("menu-icon-open");
const iconClose = document.getElementById("menu-icon-close");

if (!header || !toggle || !menu || !iconOpen || !iconClose) {
	/* elementos no encontrados — probablemente SSR */
} else {
	toggle.addEventListener("click", () => {
		const isOpen = menu.classList.toggle("hidden");
		iconOpen.classList.toggle("hidden", !isOpen);
		iconClose.classList.toggle("hidden", isOpen);
		toggle.setAttribute("aria-expanded", String(!isOpen));
	});

	menu.querySelectorAll("a").forEach((link) => {
		link.addEventListener("click", () => {
			menu.classList.add("hidden");
			iconOpen.classList.remove("hidden");
			iconClose.classList.add("hidden");
			toggle.setAttribute("aria-expanded", "false");
		});
	});
}
</script>

<style>
#mobile-menu[class*="hidden"] {
	display: none;
}

@keyframes slideDown {
	from {
		opacity: 0;
		transform: translateY(-8px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

#mobile-menu:not(.hidden) {
	display: block;
	animation: slideDown 200ms ease-out;
}
</style>
