---
import { MapRenovaBit } from "@/components/footer/MapRenovaBit";
import FacebookIcon from "@/components/social-icon/FacebookIcon.astro";
import InstagramIcon from "@/components/social-icon/InstagramIcon.astro";
import TikTokIcon from "@/components/social-icon/TikTokIcon.astro";
import { FOOTER, SITE, SOCIAL } from "@/constants";

const currentYear = new Date().getFullYear();
---

<footer class="border-t bg-background">
	<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
		<div class="grid gap-12 md:grid-cols-2 md:gap-16">
			<!-- Left: Mapa + Social -->
			<div class="flex flex-col gap-8">
				<!-- Mapa -->
				<div
					class="aspect-4/3 w-full overflow-hidden rounded-2xl border bg-card md:aspect-auto md:h-64"
				>
					<MapRenovaBit client:only="preact" />
				</div>

				<!-- Redes Sociales -->
				<div>
					<h3
						class="mb-4 font-heading text-sm font-semibold tracking-wider text-foreground uppercase"
					>
						Síguenos
					</h3>
					<div class="flex gap-3">
						<a
							href={SOCIAL.instagram}
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Instagram"
							class="flex items-center justify-center rounded-lg p-2 text-muted-foreground transition-colors hover:text-primary"
						>
							<InstagramIcon size={20} decorative />
						</a>
						<a
							href={SOCIAL.facebook}
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Facebook"
							class="flex items-center justify-center rounded-lg p-2 text-muted-foreground transition-colors hover:text-primary"
						>
							<FacebookIcon size={20} decorative />
						</a>
						<a
							href={SOCIAL.tiktok}
							target="_blank"
							rel="noopener noreferrer"
							aria-label="TikTok"
							class="flex items-center justify-center rounded-lg p-2 text-muted-foreground transition-colors hover:text-primary"
						>
							<TikTokIcon size={20} decorative />
						</a>
					</div>
				</div>
			</div>

			<!-- Right: Contacto -->
			<div class="grid grid-cols-1 gap-8 sm:grid-cols-2">
				<!-- Correos -->
				<div>
					<h3
						class="mb-3 font-heading text-sm font-semibold tracking-wider text-foreground uppercase"
					>
						Correos
					</h3>
					<ul class="space-y-1.5">
						<li>
							<a
								href={`mailto:${FOOTER.emails.info}`}
								class="text-sm text-muted-foreground transition-colors hover:text-primary"
							>
								{FOOTER.emails.info}
							</a>
						</li>
						<li>
							<a
								href={`mailto:${FOOTER.emails.contacto}`}
								class="text-sm text-muted-foreground transition-colors hover:text-primary"
							>
								{FOOTER.emails.contacto}
							</a>
						</li>
						<li>
							<a
								href={`mailto:${FOOTER.emails.soporte}`}
								class="text-sm text-muted-foreground transition-colors hover:text-primary"
							>
								{FOOTER.emails.soporte}
							</a>
						</li>
					</ul>
				</div>

				<!-- Dirección -->
				<div>
					<h3
						class="mb-3 font-heading text-sm font-semibold tracking-wider text-foreground uppercase"
					>
						Dirección
					</h3>
					<p class="text-sm leading-relaxed text-muted-foreground">
						{FOOTER.address.line1}<br>
						{FOOTER.address.city}, {FOOTER.address.district} — {FOOTER.address.postalCode}
					</p>
				</div>

				<!-- Teléfono -->
				<div>
					<h3
						class="mb-3 font-heading text-sm font-semibold tracking-wider text-foreground uppercase"
					>
						Teléfono
					</h3>
					<a
						href={`tel:${FOOTER.phone.replace(/\s/g, "")}`}
						class="text-sm text-muted-foreground transition-colors hover:text-primary"
					>
						{FOOTER.phone}
					</a>
				</div>

				<!-- Horario -->
				<div>
					<h3
						class="mb-3 font-heading text-sm font-semibold tracking-wider text-foreground uppercase"
					>
						Horario
					</h3>
					<p class="text-sm leading-relaxed text-muted-foreground">
						{FOOTER.hours}
					</p>
				</div>
			</div>
		</div>
	</div>

	<!-- Copyright -->
	<div class="border-t">
		<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
			<p class="text-center text-xs text-muted-foreground">
				&copy; {currentYear} {SITE.name}. Todos los derechos reservados.
			</p>
		</div>
	</div>
</footer>
