---
import { CONTACT, FOOTER, LOCATION, SITE, SOCIAL } from "@/constants";
import { getFeaturedFaqs } from "@/data/faq";
import { getServiceBySlug } from "@/data/servicios";
import { testimonios } from "@/data/testimonios";

const pathname = Astro.url.pathname;
const isHome = pathname === "/";

// Breadcrumb dinámico según la página
const breadcrumbItems: { name: string; item: string }[] = [{ name: "Inicio", item: SITE.url }];

if (pathname === "/servicios/") {
	breadcrumbItems.push({ name: "Servicios", item: `${SITE.url}/servicios/` });
}

// Slug de servicio: /servicios/servicio-tecnico/
const slugMatch = pathname.match(/^\/servicios\/([^/]+)\/$/);
if (slugMatch) {
	const serviceSlug = slugMatch[1];
	const service = getServiceBySlug(serviceSlug);
	breadcrumbItems.push({ name: "Servicios", item: `${SITE.url}/servicios/` });
	if (service) {
		breadcrumbItems.push({
			name: service.title,
			item: `${SITE.url}/servicios/${serviceSlug}/`,
		});
	}
}

// Solo homepage incluye FAQ (solo las destacadas)
const faqEntity = isHome
	? {
			"@type": "FAQPage",
			"@id": `${SITE.url}/#faq`,
			mainEntity: getFeaturedFaqs().map((item) => ({
				"@type": "Question",
				name: item.question,
				acceptedAnswer: {
					"@type": "Answer",
					text: item.answer,
				},
			})),
		}
	: null;

// Graph: entidades comunes + condicionales
const graphEntities: Record<string, unknown>[] = [
	{
		"@type": "Organization",
		"@id": `${SITE.url}/#organization`,
		name: SITE.name,
		url: SITE.url,
		description: SITE.description,
		logo: `${SITE.url}${SITE.ogImage}`,
		founder: {
			"@type": "Person",
			name: "Reyser Zapata",
		},
		knowsAbout: [
			"Reparación de laptops",
			"Mantenimiento de computadoras",
			"Desarrollo web",
			"Landing pages",
			"Microelectrónica",
			"Soporte técnico",
			"Armado de PCs",
			"Venta de componentes",
			"Diagnóstico de hardware",
			"Instalación de sistemas operativos",
		],
		contactPoint: {
			"@type": "ContactPoint",
			telephone: CONTACT.phone,
			email: CONTACT.email,
			contactType: "customer service",
			availableLanguage: ["Spanish"],
		},
		sameAs: [SOCIAL.instagram, SOCIAL.facebook, SOCIAL.tiktok, SOCIAL.x, SOCIAL.github],
	},
	{
		"@type": "LocalBusiness",
		"@id": `${SITE.url}/#business`,
		name: SITE.name,
		description: SITE.description,
		url: SITE.url,
		telephone: CONTACT.phone,
		email: CONTACT.email,
		image: `${SITE.url}${SITE.ogImage}`,
		address: {
			"@type": "PostalAddress",
			streetAddress: FOOTER.address.line1,
			addressLocality: FOOTER.address.city,
			addressRegion: FOOTER.address.district,
			postalCode: FOOTER.address.postalCode,
			addressCountry: "PE",
		},
		geo: {
			"@type": "GeoCoordinates",
			latitude: LOCATION.lat,
			longitude: LOCATION.lng,
		},
		openingHoursSpecification: {
			"@type": "OpeningHoursSpecification",
			dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
			opens: "08:00",
			closes: "20:00",
		},
		priceRange: "Desde S/90",
		currenciesAccepted: "PEN",
		areaServed: {
			"@type": "GeoCircle",
			geoMidpoint: {
				"@type": "GeoCoordinates",
				latitude: LOCATION.lat,
				longitude: LOCATION.lng,
			},
			geoRadius: "50000",
		},
		aggregateRating: {
			"@type": "AggregateRating",
			ratingValue: (testimonios.reduce((sum, t) => sum + t.rating, 0) / testimonios.length).toFixed(
				1,
			),
			reviewCount: String(testimonios.length),
			bestRating: "5",
			worstRating: "1",
		},
		review: testimonios.map((t) => ({
			"@type": "Review",
			"@id": `${SITE.url}/#review-${t.id}`,
			author: {
				"@type": "Person",
				name: t.autor,
			},
			datePublished: t.fecha,
			reviewBody: t.texto,
			reviewRating: {
				"@type": "Rating",
				ratingValue: String(t.rating),
				bestRating: "5",
				worstRating: "1",
			},
			itemReviewed: {
				"@id": `${SITE.url}/#business`,
			},
		})),
		hasOfferCatalog: {
			"@type": "OfferCatalog",
			name: "Servicios de RenovaBit",
			itemListElement: [
				{
					"@type": "Offer",
					itemOffered: {
						"@type": "Service",
						name: "Servicio Técnico de Laptops y PCs",
						description:
							"Mantenimiento preventivo y correctivo, limpieza, diagnóstico y reparación de laptops y computadoras de escritorio en Arequipa.",
					},
				},
				{
					"@type": "Offer",
					itemOffered: {
						"@type": "Service",
						name: "Desarrollo Web",
						description:
							"Landing pages, sitios web corporativos, catálogos digitales y automatizaciones para negocios en Arequipa.",
					},
				},
				{
					"@type": "Offer",
					itemOffered: {
						"@type": "Service",
						name: "Venta de Componentes y Equipos",
						description:
							"Venta de laptops, PCs, componentes, periféricos y accesorios. Equipos nuevos y upgrades en Arequipa.",
					},
				},
				{
					"@type": "Offer",
					itemOffered: {
						"@type": "Service",
						name: "Reparaciones Especializadas",
						description:
							"Reparación de motherboard, microelectrónica, BIOS, cambio de pantallas y teclados de laptop en Arequipa.",
					},
				},
			],
		},
	},
	{
		"@type": "WebSite",
		"@id": `${SITE.url}/#website`,
		url: SITE.url,
		name: SITE.name,
		description: SITE.description,
		inLanguage: "es-PE",
		potentialAction: {
			"@type": "SearchAction",
			target: {
				"@type": "EntryPoint",
				urlTemplate: `${SITE.url}/?s={search_term_string}`,
			},
			"query-input": "required name=search_term_string",
		},
	},
	{
		"@type": "BreadcrumbList",
		"@id": `${SITE.url}/#breadcrumb`,
		itemListElement: breadcrumbItems.map((item, i) => ({
			"@type": "ListItem",
			position: i + 1,
			name: item.name,
			item: item.item,
		})),
	},
];

if (faqEntity) {
	graphEntities.push(faqEntity);
}

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": graphEntities,
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
