---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Icon } from "astro-icon/components";
import WhatsappIcon from "@/components/social-icon/WhatsappIcon.astro";
import { Button } from "@/components/ui/button";
import { CONTACT } from "@/constants";

interface Props {
	heroImg: ImageMetadata;
	includes: string[];
	symptoms: string[];
	ctaLabel: string;
}

const { heroImg, includes, symptoms, ctaLabel } = Astro.props;

interface Tier {
	name: string;
	badge?: string;
	price: string;
	usage: string;
	items: string[];
}

const tiers: Tier[] = [
	{
		name: "Básico",
		price: "S/ 90",
		usage: "Uso diario y oficina",
		items: [
			"Limpieza interna profunda con aire controlado",
			"Cambio de pasta térmica Arctic MX-4",
			"Lubricación de ventiladores",
			"Limpieza de pantalla, teclado y conectores",
			"Pruebas de temperatura e informe del trabajo",
		],
	},
	{
		name: "Gaming",
		badge: "Recomendado",
		price: "S/ 120",
		usage: "Alto rendimiento y gaming",
		items: [
			"Todo lo del Básico",
			"Pasta térmica Arctic MX-6 de alto rendimiento",
			"Reemplazo de pads térmicos",
			"Optimización de curvas de ventilación",
			"Pruebas de estrés térmico e informe con métricas",
		],
	},
	{
		name: "Empresarial",
		price: "Presupuesto",
		usage: "Flotas de equipos y empresas",
		items: [
			"Varios equipos atendidos en lote",
			"Informe técnico + evidencia fotográfica por equipo",
			"Factura electrónica y documentación contable",
			"Atención programada recurrente",
			"Inventario de estado y prioridad en agenda",
		],
	},
];

interface Step {
	title: string;
	description: string;
}

const processSteps: Step[] = [
	{
		title: "Desarme completo, sin improvisar",
		description:
			"Desmontamos cada pieza con las herramientas correctas. Cada tornillo va a su lugar. Nada de palancas ni destornilladores que no corresponden.",
	},
	{
		title: "Limpieza profunda, interior y exterior",
		description:
			"Aire a presión controlada para el interior. Alcohol isopropílico para conectores y contactos. Limpieza manual de pantalla, teclado y carcasa. Tu laptop debería verse y sentirse como nueva.",
	},
	{
		title: "Pasta térmica de verdad",
		description:
			"Usamos Arctic MX-4 de fábrica y MX-6 de alto rendimiento para equipos exigentes. Nada de pasta genérica que se seca en tres meses. También reemplazamos pads térmicos deteriorados.",
	},
	{
		title: "Ventiladores lubricados, no ruidosos",
		description:
			"Desmontamos cada ventilador, lo limpiamos a fondo y lo lubricamos. Después del mantenimiento tu laptop debería escucharse apenas, incluso en carga.",
	},
	{
		title: "Pruebas, no promesas",
		description:
			"Medimos temperaturas antes y después. Probamos cada componente. Si algo no está bien — un ventilador que pierde fuerza, una batería hinchada, un tornillo faltante — te lo decimos con foto antes de hacer nada extra. Sin sorpresas en la factura.",
	},
];

const checkIcon = "hugeicons:checkmark-circle-03";
const checkIconClass = "mt-0.5 size-3.5 shrink-0 text-primary/60";
---

<!-- Niveles de mantenimiento -->
<section class="border-t py-16 md:py-20">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
			<div
				class="-mx-4 overflow-hidden sm:mx-0 sm:rounded-2xl sm:border sm:border-border/20 lg:sticky lg:top-24"
			>
				<Image
					src={heroImg}
					alt="Mantenimiento profesional de laptop en RenovaBit"
					widths={[600, 800]}
					sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 50vw"
					loading="lazy"
					class="w-full object-cover aspect-4/3"
				/>
			</div>

			<div>
				<h2 class="font-heading text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
					Tres niveles de mantenimiento
				</h2>
				<p class="mt-4 text-base leading-relaxed text-muted-foreground">
					No todos los equipos se usan igual. Una laptop de oficina no necesita lo mismo que una
					máquina gamer o una estación de trabajo.
				</p>

				<div class="mt-8 space-y-6">
					{tiers.map((tier) => (
						<div class="border-t border-border/20 pt-4">
							<div class="flex items-baseline justify-between gap-4">
								<h3 class="font-heading text-base font-bold text-foreground">
									{tier.name}
									{tier.badge && (
										<span class="rounded bg-primary/10 px-1.5 py-0.5 text-[10px] font-semibold text-primary uppercase">
											{tier.badge}
										</span>
									)}
								</h3>
								<span class="shrink-0 font-mono text-lg font-bold text-foreground">{tier.price}</span>
							</div>
							<p class="mt-1 text-sm text-muted-foreground">{tier.usage}</p>
							<ul class="mt-3 space-y-1.5 space-x-2">
								{tier.items.map((item) => (
									<li class="inline-flex items-start gap-2 text-sm text-muted-foreground">
										<Icon name={checkIcon} class={checkIconClass} />{item}
									</li>
								))}
							</ul>
						</div>
					))}
				</div>

				<div class="mt-6">
					<Button
						as="a"
						href={CONTACT.whatsappUrl}
						target="_blank"
						rel="noopener noreferrer"
						variant="whatsapp"
						size="lg"
						class="gap-2"
					>
						<WhatsappIcon size={18} />{ctaLabel}
					</Button>
				</div>
			</div>
		</div>
	</div>
</section>

<!-- Síntomas -->
<section class="py-16 bg-muted/15 md:py-20">
	<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
		<h2 class="font-heading text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
			¿Tu equipo tiene estos síntomas?
		</h2>
		<p class="mt-4 text-base leading-relaxed text-muted-foreground">
			Si reconoces alguno, es muy probable que solo necesite un buen mantenimiento. No hace falta
			cambiar de laptop.
		</p>
		<div class="mt-8 grid gap-x-8 gap-y-3 sm:grid-cols-2">
			{symptoms.map((s) => (
				<p class="inline-flex items-start gap-2.5 text-sm text-muted-foreground">
					<Icon name={checkIcon} class={checkIconClass} />{s}
				</p>
			))}
		</div>
		<div class="mt-8">
			<Button
				as="a"
				href={CONTACT.whatsappUrl}
				target="_blank"
				rel="noopener noreferrer"
				variant="outline"
				size="lg"
				class="gap-2"
			>
				Sí, eso me pasa <WhatsappIcon size={16} />
			</Button>
		</div>
	</div>
</section>

<!-- Cómo trabajamos -->
<section class="py-16 md:py-20">
	<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
		<h2 class="font-heading text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
			No es solo "limpiar con aire"
		</h2>
		<p class="mt-4 text-base leading-relaxed text-muted-foreground">
			Muchos técnicos abren la laptop, le pasan un soplador y la cierran. No revisan temperaturas,
			no lubrican ventiladores, no cambian la pasta como corresponde. Nosotros hacemos las cosas
			distintas.
		</p>

		<ol class="mt-10 space-y-8">
			{processSteps.map((step, i) => (
				<li class="flex gap-4">
					<span class="flex size-7 shrink-0 items-center justify-center rounded-full border border-border/30 font-mono text-xs font-medium text-muted-foreground">
						{i + 1}
					</span>
					<div>
						<h3 class="font-heading text-base font-bold text-foreground">{step.title}</h3>
						<p class="mt-1 text-sm leading-relaxed text-muted-foreground">{step.description}</p>
					</div>
				</li>
			))}
		</ol>

		<div class="mt-10">
			<Button
				as="a"
				href={CONTACT.whatsappUrl}
				target="_blank"
				rel="noopener noreferrer"
				variant="whatsapp"
				size="lg"
				class="gap-2"
			>
				<WhatsappIcon size={18} />{ctaLabel}
			</Button>
		</div>
	</div>
</section>

<!-- Qué incluye -->
<section class="border-t py-16 md:py-20">
	<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
		<h2 class="font-heading text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
			Qué incluye cada mantenimiento
		</h2>
		<p class="mt-4 text-base leading-relaxed text-muted-foreground">
			Independientemente del nivel que elijas, hay cosas que son estándar en todos nuestros
			servicios. Porque no deberías tener que pagar extra por que te traten bien.
		</p>

		<div class="mt-8 grid gap-x-8 gap-y-3 sm:grid-cols-2">
			{includes.map((item) => (
				<p class="inline-flex items-start gap-2.5 text-sm text-muted-foreground">
					<Icon name={checkIcon} class={checkIconClass} />{item}
				</p>
			))}
		</div>

		<div class="mt-8">
			<Button
				as="a"
				href={CONTACT.whatsappUrl}
				target="_blank"
				rel="noopener noreferrer"
				variant="whatsapp"
				size="lg"
				class="gap-2"
			>
				<WhatsappIcon size={18} />{ctaLabel}
			</Button>
		</div>
	</div>
</section>
