---
interface Props {
	number: string;
	price: string;
	subtitle: string;
	title: string;
	description: string;
	descriptionWidth?: "md" | "lg";
}

const { number, price, subtitle, title, description, descriptionWidth = "md" } = Astro.props;

const maxWidthClass = descriptionWidth === "lg" ? "max-w-lg" : "max-w-md";
---

<div class="relative">
	<span
		class="absolute -top-14 -left-4 font-heading text-[11rem] font-black leading-none tracking-tighter text-primary/3 select-none pointer-events-none"
	>
		{number}
	</span>
	<div class="relative">
		<p class="font-heading text-6xl font-black leading-none tracking-tighter text-foreground">
			{price}
		</p>
		<p
			class="mt-1 font-mono text-[11px] font-medium tracking-widest text-muted-foreground uppercase"
		>
			{subtitle}
		</p>
		<div class="mt-5 h-0.5 w-10 bg-primary/60" />
		<h2 class="mt-5 font-heading text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
			{title}
		</h2>
		<p class={`mt-3 text-base leading-relaxed text-muted-foreground ${maxWidthClass}`}>
			{description}
		</p>
	</div>
</div>
