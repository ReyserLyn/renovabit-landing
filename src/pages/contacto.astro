---
import { Icon } from "astro-icon/components";
import { MapRenovaBit } from "@/components/footer/MapRenovaBit";
import WhatsappIcon from "@/components/social-icon/WhatsappIcon.astro";
import { Button } from "@/components/ui/button";
import { CONTACT, FOOTER, LOCATION, SITE } from "@/constants";
import BaseLayout from "@/layouts/BaseLayout.astro";

const details = [
	{
		icon: "hugeicons:maps",
		label: "Dirección",
		value: `${FOOTER.address.line1}, ${FOOTER.address.city}, ${FOOTER.address.district} — ${FOOTER.address.postalCode}`,
		href: `https://www.google.com/maps?q=${LOCATION.lat},${LOCATION.lng}`,
		cta: "Abrir en Google Maps",
	},
	{
		icon: "hugeicons:telephone",
		label: "Teléfono",
		value: CONTACT.phone,
		href: `tel:${CONTACT.phone}`,
		cta: "Llamar ahora",
	},
	{
		icon: "hugeicons:clock-01",
		label: "Horario",
		value: FOOTER.hours,
	},
	{
		icon: "hugeicons:mail-01",
		label: "Correo",
		value: FOOTER.emails.contacto,
		href: `mailto:${FOOTER.emails.contacto}`,
		cta: "Enviar correo",
	},
];
---

<BaseLayout
	title="Contacto y Ubicación en Arequipa"
	description="Encuentra a RenovaBit en Av. Goyeneche 1602, Miraflores, Arequipa. Teléfono, WhatsApp, horarios y ubicación. Atención de lunes a viernes de 8:00 AM a 8:00 PM."
>
	<!-- Hero -->
	<section class="pt-32 pb-12 md:pt-40 md:pb-16">
		<div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
			<p class="font-mono text-xs font-medium tracking-widest text-primary uppercase">
				Dónde encontrarnos
			</p>
			<h1
				class="mt-3 font-heading text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl"
			>
				Contacto y ubicación
			</h1>
			<p class="mt-4 text-lg leading-relaxed text-muted-foreground sm:text-xl">
				Estamos en Miraflores, Arequipa. Escribe, llama o pasa por el taller.
			</p>
		</div>
	</section>

	<!-- Mapa y datos -->
	<section class="border-t py-16 md:py-20">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="grid gap-10 lg:grid-cols-5 lg:gap-16">
				<!-- Mapa -->
				<div
					class="overflow-hidden rounded-2xl border border-border/20 lg:col-span-3 lg:sticky lg:top-24"
					style="min-height:450px"
				>
					<MapRenovaBit client:visible />
				</div>

				<!-- Info -->
				<div class="lg:col-span-2">
					<h2 class="font-heading text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
						Visítanos
					</h2>
					<p class="mt-4 text-base leading-relaxed text-muted-foreground">
						El taller está abierto al público. Si vienes, avísanos antes por WhatsApp para
						asegurarnos de que estemos disponibles.
					</p>

					<div class="mt-8 space-y-6">
						{details.map((d) => (
							<div class="border-t border-border/20 pt-4">
								<div class="flex items-start gap-3">
									<Icon name={d.icon} class="mt-0.5 size-5 shrink-0 text-primary/70" />
									<div>
										<h3 class="font-heading text-sm font-bold text-foreground uppercase tracking-wider">{d.label}</h3>
										<p class="mt-1 text-base text-muted-foreground">{d.value}</p>
										{d.href && d.cta && (
											<a
												href={d.href}
												class="mt-2 inline-flex items-center gap-1.5 text-sm font-medium text-primary hover:underline"
											>
												{d.cta}
												<Icon name="hugeicons:arrow-right-01" class="size-3.5" />
											</a>
										)}
									</div>
								</div>
							</div>
						))}
					</div>

					<div class="mt-8">
						<Button
							as="a"
							href={CONTACT.whatsappUrl}
							target="_blank"
							rel="noopener noreferrer"
							variant="whatsapp"
							size="lg"
							class="gap-2"
						>
							<WhatsappIcon size={18} />Escríbenos por WhatsApp
						</Button>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="py-20 md:py-28">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div
				class="flex flex-col items-center gap-8 rounded-2xl bg-primary px-6 py-12 text-center sm:px-10 sm:py-14 md:flex-row md:justify-between md:text-left lg:px-14 lg:py-16"
			>
				<div class="max-w-xl">
					<h2
						class="font-heading text-2xl font-bold tracking-tight text-primary-foreground sm:text-3xl lg:text-4xl"
					>
						¿Prefieres que te llamemos?
					</h2>
					<p class="mt-4 text-base leading-relaxed text-primary-foreground sm:text-lg">
						Déjanos tu número por WhatsApp y te contactamos en minutos.
					</p>
				</div>

				<Button
					as="a"
					href={CONTACT.whatsappUrl}
					target="_blank"
					rel="noopener noreferrer"
					variant="default"
					size="lg"
					class="shrink-0 gap-2 border border-white/20 bg-white text-primary hover:bg-white/90"
				>
					<WhatsappIcon size={18} />
					Escríbenos
				</Button>
			</div>
		</div>
	</section>
</BaseLayout>
