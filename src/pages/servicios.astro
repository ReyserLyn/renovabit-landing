---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import TrustMarquee from "@/components/sections/trust-marquee.astro";
import ServiceBulletList from "@/components/services/ServiceBulletList.astro";
import ServiceCTA from "@/components/services/ServiceCTA.astro";
import ServiceFeatureGrid from "@/components/services/ServiceFeatureGrid.astro";
import ServiceInfoCard from "@/components/services/ServiceInfoCard.astro";
import ServicePriceBlock from "@/components/services/ServicePriceBlock.astro";
import WhatsappIcon from "@/components/social-icon/WhatsappIcon.astro";
import { Button } from "@/components/ui/button";
import { CONTACT } from "@/constants";
import { servicios } from "@/data/servicios";
import BaseLayout from "@/layouts/BaseLayout.astro";

const [srv1, srv2, srv3, srv4] = servicios;
---

<BaseLayout
	title="Servicio Técnico y Desarrollo Web en Arequipa"
	description="Servicio técnico de laptops y PCs, desarrollo web, tienda de componentes y reparaciones especializadas en Arequipa. Diagnóstico gratuito."
	ogImage="/og-servicios.jpg"
>
	<!-- Page hero -->
	<section class="pt-32 pb-12 md:pt-40 md:pb-16">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="mx-auto max-w-3xl text-center">
				<p
					class="font-mono text-xs font-medium tracking-widest text-primary uppercase animate-fade-in-up animate-duration-normal"
				>
					Nuestros servicios
				</p>
				<h1
					class="mt-3 font-heading text-4xl font-bold tracking-tight text-foreground sm:text-5xl animate-fade-in-up animate-delay-100 animate-duration-normal"
				>
					Cuatro soluciones tecnológicas.
					<br>
					<span class="text-muted-foreground">Una misma forma de trabajar.</span>
				</h1>
				<p
					class="mt-4 text-lg leading-relaxed text-muted-foreground animate-fade-in-up animate-delay-200 animate-duration-normal"
				>
					Diagnóstico claro, comunicación transparente y trabajos documentados para personas,
					empresas y emprendimientos en Arequipa.
				</p>
			</div>
		</div>
	</section>

	<!-- ===== VARIANTE A: Split 60/40 ===== -->
	<!-- Servicio 1: Servicio Técnico -->
	<section id="servicio-tecnico" class="py-16">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="grid gap-10 items-center lg:grid-cols-12 lg:gap-16">
				<!-- Imagen — 7 cols -->
				<div class="lg:col-span-7">
					<div
						class="relative overflow-hidden rounded-2xl border border-border/20 lg:animate-blurred-fade-in lg:animate-delay-300 lg:animate-duration-normal max-lg:timeline-view max-lg:animate-blurred-fade-in max-lg:animate-range-[entry_3%_contain_10%]"
					>
						<Image
							src={srv1.heroImg}
							alt="Taller completo de RenovaBit con herramientas y equipos de reparación profesional en Arequipa"
							widths={[600, 900]}
							sizes="(max-width: 768px) 100vw, 58vw"
							fetchpriority="high"
							loading="eager"
							class="w-full object-cover aspect-4/3 animate-blurred-fade-in animate-delay-300 animate-duration-normal"
						/>
					</div>
					<div class="animate-blurred-fade-in animate-delay-350 animate-duration-normal">
						<ServiceInfoCard service={srv1} />
					</div>
				</div>

				<!-- Contenido — 5 cols -->
				<div class="lg:col-span-5">
					<div
						class="lg:animate-fade-in-up lg:animate-delay-300 lg:animate-duration-normal max-lg:timeline-view max-lg:animate-fade-in-up max-lg:animate-range-[entry_2%_contain_8%]"
					>
						<ServicePriceBlock service={srv1} number="01" />
					</div>
					<div
						class="lg:animate-fade-in-up lg:animate-delay-400 lg:animate-duration-normal max-lg:timeline-view max-lg:animate-fade-in-up max-lg:animate-range-[entry_3%_contain_10%]"
					>
						<ServiceBulletList items={srv1.includes.slice(0, 5)} />
					</div>
					<div
						class="lg:animate-fade-in-up lg:animate-delay-500 lg:animate-duration-normal max-lg:timeline-view max-lg:animate-fade-in-up max-lg:animate-range-[entry_4%_contain_10%]"
					>
						<ServiceCTA
							service={srv1}
							footerText="Atención en Arequipa · Boleta y factura · Garantía · Diagnóstico profesional"
							secondaryHref="/servicios/servicio-tecnico/"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== VARIANTE B: Image Hero (imagen compacta arriba, contenido abajo) ===== -->
	<!-- Servicio 2: Desarrollo Web -->
	<section id="desarrollo-web" class="border-t py-16 bg-muted/15">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div
				class="mx-auto max-w-4xl overflow-hidden rounded-2xl border border-border/20 timeline-view animate-blurred-fade-in animate-range-[entry_3%_contain_10%]"
			>
				<Image
					src={srv2.heroImg}
					alt="Desarrollo web corporativo: sitio de Bodega Manchego, proyecto reciente de RenovaBit"
					widths={[600, 1000]}
					sizes="(max-width: 768px) 100vw, 80vw"
					loading="lazy"
					class="w-full object-cover aspect-video"
				/>
			</div>

			<div class="mx-auto mt-10 max-w-3xl">
				<div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between lg:gap-12">
					<div class="timeline-view animate-fade-in-up animate-range-[entry_2%_contain_8%]">
						<ServiceInfoCard service={srv2} variant="vertical" />
					</div>

					<div class="order-last lg:order-first">
						<div class="timeline-view animate-fade-in-up animate-range-[entry_3%_contain_10%]">
							<ServicePriceBlock service={srv2} number="02" descriptionWidth="lg" />
						</div>
						<div
							class="mt-6 flex flex-wrap items-center gap-3 timeline-view animate-fade-in-up animate-range-[entry_5%_contain_12%]"
						>
							<Button
								as="a"
								href={CONTACT.whatsappUrl}
								target="_blank"
								rel="noopener noreferrer"
								variant="whatsapp"
								size="lg"
								class="gap-2"
							>
								<WhatsappIcon size={18} />{srv2.ctaLabel}
							</Button>
							<Button
								as="a"
								href="/servicios/desarrollo-web/"
								variant="outline"
								size="lg"
								class="gap-2"
							>
								<Icon name="hugeicons:arrow-right-01" class="size-4" />Ver servicio completo
							</Button>
						</div>
					</div>
				</div>

				{srv2.features && (
				<div class="timeline-view animate-fade-in-up animate-range-[entry_4%_contain_10%]">
					<ServiceFeatureGrid features={srv2.features} />
				</div>
			)}

				<p class="mt-8 text-[11px] text-muted-foreground/70">
					Atención en Arequipa · Boleta y factura · Garantía · Diagnóstico profesional · Soporte
					post-entrega
				</p>
			</div>
		</div>
	</section>

	<!-- Trust Marquee -->
	<div class="border-y py-12">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<TrustMarquee separator={false} />
		</div>
	</div>

	<!-- ===== VARIANTE A (repeat): Tienda ===== -->
	<section id="tienda" class="py-16">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="grid gap-10 items-center lg:grid-cols-12 lg:gap-16">
				<!-- Imagen — 7 cols -->
				<div class="lg:col-span-7 lg:order-2">
					<div
						class="relative overflow-hidden rounded-2xl timeline-view animate-blurred-fade-in animate-range-[entry_3%_contain_10%]"
					>
						<Image
							src={srv3.heroImg}
							alt="Tienda online de RenovaBit: venta de equipos, componentes y periféricos"
							widths={[600, 900]}
							sizes="(max-width: 768px) 100vw, 58vw"
							loading="lazy"
							class="w-full object-cover aspect-4/3"
						/>
					</div>
					<ServiceInfoCard service={srv3} />
				</div>

				<!-- Contenido — 5 cols -->
				<div class="lg:col-span-5 lg:order-1">
					<div class="timeline-view animate-fade-in-up animate-range-[entry_2%_contain_8%]">
						<ServicePriceBlock service={srv3} number="03" />
					</div>
					<div class="timeline-view animate-fade-in-up animate-range-[entry_3%_contain_10%]">
						<ServiceBulletList items={srv3.includes.slice(0, 5)} />
					</div>
					<div class="timeline-view animate-fade-in-up animate-range-[entry_5%_contain_12%]">
						<ServiceCTA
							service={srv3}
							footerText="Atención en Arequipa · Boleta y factura · Garantía · Diagnóstico profesional"
							secondaryHref="/servicios/tienda/"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ===== VARIANTE B (repeat): Reparaciones Especializadas ===== -->
	<section id="reparaciones-especializadas" class="border-t py-16 bg-muted/15">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div
				class="mx-auto max-w-4xl overflow-hidden rounded-2xl border border-border/20 timeline-view animate-blurred-fade-in animate-range-[entry_3%_contain_10%]"
			>
				<Image
					src={srv4.heroImg}
					alt="Placa de laptop Lenovo ThinkPad tras mantenimiento profesional RenovaBit"
					widths={[600, 1000]}
					sizes="(max-width: 768px) 100vw, 80vw"
					loading="lazy"
					class="w-full object-cover aspect-video"
				/>
			</div>

			<div class="mx-auto mt-10 max-w-3xl">
				<div class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between lg:gap-12">
					<div class="timeline-view animate-fade-in-up animate-range-[entry_2%_contain_8%]">
						<ServiceInfoCard service={srv4} variant="vertical" />
					</div>

					<div class="order-last lg:order-first">
						<div class="timeline-view animate-fade-in-up animate-range-[entry_3%_contain_10%]">
							<ServicePriceBlock service={srv4} number="04" descriptionWidth="lg" />
						</div>
						<div
							class="mt-6 flex flex-wrap items-center gap-3 timeline-view animate-fade-in-up animate-range-[entry_5%_contain_12%]"
						>
							<Button
								as="a"
								href={CONTACT.whatsappUrl}
								target="_blank"
								rel="noopener noreferrer"
								variant="whatsapp"
								size="lg"
								class="gap-2"
							>
								<WhatsappIcon size={18} />{srv4.ctaLabel}
							</Button>
							<Button
								as="a"
								href="/servicios/reparaciones-especializadas/"
								variant="outline"
								size="lg"
								class="gap-2"
							>
								<Icon name="hugeicons:arrow-right-01" class="size-4" />Ver servicio completo
							</Button>
						</div>
					</div>
				</div>

				{srv4.features && (
				<div class="timeline-view animate-fade-in-up animate-range-[entry_4%_contain_10%]">
					<ServiceFeatureGrid features={srv4.features} />
				</div>
			)}

				<p class="mt-8 text-[11px] text-muted-foreground/70">
					Atención en Arequipa · Boleta y factura · Garantía · Diagnóstico profesional · Equipo
					profesional
				</p>
			</div>
		</div>
	</section>

	<!-- ===== CTA Final ===== -->
	<section class="py-20 md:py-28">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div
				class="flex flex-col items-center gap-8 rounded-2xl bg-primary px-6 py-12 text-center sm:px-10 sm:py-14 md:flex-row md:justify-between md:text-left lg:px-14 lg:py-16 timeline-view animate-fade-in-up animate-range-[entry_3%_contain_10%] animate-duration-slower"
			>
				<div class="max-w-xl">
					<h2
						class="font-heading text-2xl font-bold tracking-tight text-primary-foreground sm:text-3xl lg:text-4xl"
					>
						¿Qué servicio necesitas?
					</h2>
					<p class="mt-4 text-base leading-relaxed text-primary-foreground sm:text-lg">
						Contanos cuál te interesa y te preparamos una cotización clara, sin compromiso y
						adaptada a tu caso.
					</p>
				</div>

				<Button
					as="a"
					href={CONTACT.whatsappUrl}
					target="_blank"
					rel="noopener noreferrer"
					variant="default"
					size="lg"
					class="shrink-0 gap-2 border border-white/20 bg-white text-primary hover:bg-white/90"
				>
					<WhatsappIcon size={18} />
					Escríbenos por WhatsApp
				</Button>
			</div>
		</div>
	</section>
</BaseLayout>
