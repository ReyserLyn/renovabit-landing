---
import GridDotsBackground from "@astroanimate/core/GridDotsBackground";
import WhatsappIcon from "@/components/social-icon/WhatsappIcon.astro";
import { Button } from "@/components/ui/button";
import { CONTACT } from "@/constants";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
	title="Página no encontrada"
	description="La página que buscas no existe o fue movida. Vuelve al inicio o escríbenos por WhatsApp para ayudarte."
>
	<GridDotsBackground
		variant="dots"
		height="100%"
		bgColor="transparent"
		dotColor="oklch(0.57 0.2248 281.4451 / 0.06)"
		gap="28px"
	>
		<section class="relative z-10 flex min-h-dvh items-center justify-center px-4">
			<div class="mx-auto flex max-w-lg flex-col items-center text-center">
				<!-- Logo -->
				<img
					src="/logo-horizontal-light.svg"
					alt="RenovaBit"
					class="mb-10 h-auto w-56 animate-fade-in-up animate-duration-normal"
					loading="eager"
				>

				<!-- Número 404 -->
				<p
					class="font-heading text-8xl font-black leading-none tracking-tighter text-primary/15 select-none animate-fade-in-up animate-delay-100 animate-duration-normal"
				>
					404
				</p>

				<!-- Texto -->
				<h1
					class="mt-4 font-heading text-2xl font-bold tracking-tight text-foreground sm:text-3xl animate-fade-in-up animate-delay-200 animate-duration-normal"
				>
					Esta página no existe
				</h1>
				<p
					class="mt-3 max-w-sm text-base leading-relaxed text-muted-foreground animate-fade-in-up animate-delay-300 animate-duration-normal"
				>
					Parece que la página que buscas fue movida, renombrada o nunca existió. Pero no te
					preocupes — podemos ayudarte igual.
				</p>

				<!-- Botones -->
				<div
					class="mt-7 flex flex-wrap justify-center gap-3 sm:gap-4 animate-fade-in-up animate-delay-400 animate-duration-normal"
				>
					<Button as="a" href="/" variant="default" size="lg" class="gap-2">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 24 24"
							width="20"
							height="20"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="shrink-0"
							aria-hidden="true"
						>
							<path d="M19 12H5M12 5l-7 7 7 7" />
						</svg>
						Volver al inicio
					</Button>
					<Button
						as="a"
						href={CONTACT.whatsappUrl}
						target="_blank"
						rel="noopener noreferrer"
						variant="whatsapp"
						size="lg"
						class="gap-2"
					>
						<WhatsappIcon size={18} />Escríbenos
					</Button>
				</div>
			</div>
		</section>
	</GridDotsBackground>
</BaseLayout>
